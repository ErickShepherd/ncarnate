version: "2.0.1"
date-released: "2026-07-09"
license: MIT
repository-code: "https://github.com/ErickShepherd/ncarnate"
url: "https://github.com/ErickShepherd/ncarnate"
keywords:
  - netCDF
  - HDF4
  - HDF-EOS2
  - compression
  - CF conventions
  - atmospheric science
  - remote sensing
