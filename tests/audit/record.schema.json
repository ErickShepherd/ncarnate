{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ncarnate audit record (migration manifest, schema v1)",
  "description": "One per-file record; every JSONL line is exactly this shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "ncarnate_version", "ruleset_version", "mode",
    "audited_at", "root", "path", "size_bytes", "sha256", "format",
    "status", "structures", "issues", "plan"
  ],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "ncarnate_version": {"type": "string"},
    "ruleset_version": {"type": "integer"},
    "mode": {"type": "string"},
    "audited_at": {"type": "string"},
    "root": {"type": "string"},
    "path": {"type": "string"},
    "size_bytes": {"type": "integer"},
    "sha256": {"type": ["string", "null"]},
    "format": {"type": "string"},
    "status": {
      "type": "string",
      "enum": [
        "ready", "ready_no_geolocation", "already_modern",
        "unsupported", "malformed", "unsafe", "unknown"
      ]
    },
    "structures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "name", "projection", "geolocation_plan"],
        "properties": {
          "type": {"type": "string"},
          "name": {"type": "string"},
          "projection": {"type": ["object", "null"]},
          "geolocation_plan": {"type": ["object", "null"]}
        }
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "severity", "message", "context"],
        "properties": {
          "code": {"type": "string"},
          "severity": {"type": "string", "enum": ["info", "warning", "blocker"]},
          "message": {"type": "string"},
          "context": {"type": "object"}
        }
      }
    },
    "plan": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["operation", "geolocation_method", "output_format"],
      "properties": {
        "operation": {"type": "string"},
        "geolocation_method": {"type": ["string", "null"]},
        "output_format": {"type": "string"}
      }
    }
  }
}
